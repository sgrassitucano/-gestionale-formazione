{
  "name": "@gestionale/db",
  "version": "0.1.0",
  "description": "Prisma database schema and client for Gestionale Formazione",
  "private": true,
  "main": "src/client.ts",
  "exports": {
    ".": "./src/client.ts",
    "./seed": "./src/seeds/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node --import tsx src/seeds/seed.ts",
    "db:seed:corsi": "node --import tsx src/seeds/seedCorsi.ts",
    "db:seed:listini": "node --import tsx src/seeds/seedListini.ts",
    "db:reset": "prisma migrate reset",
    "db:status": "prisma migrate status",
    "db:push": "prisma db push"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prisma": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@gestionale/types": "*",
    "@gestionale/utils": "*",
    "tweetnacl": "^1.0.3",
    "bcryptjs": "^2.4.3"
  }
}
