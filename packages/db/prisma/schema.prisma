// Gestionale Formazione — Prisma Schema
// Database: PostgreSQL (Supabase)
// RLS: Enabled per tutte le tabelle
// Encryption: Via middleware Prisma (CF, data_nascita, cellulare, email)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// MODULO 1: AUTENTICAZIONE E PERMESSI
// ============================================================================

enum Ruolo {
  SUPERADMIN
  SEGRETERIA
  AMMINISTRAZIONE
  VISUALIZZATORE
}

model ProfiloUtente {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String
  ruolo                Ruolo
  nome                 String?
  cognome              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime? // soft-delete

  // Relazioni
  logAudit             LogAudit[]
  importLog            ImportLog[]
  templatesCreati      Template[] @relation("createdBy")
  archivioUpload       ArchivioAula[] @relation("uploadedBy")

  @@index([ruolo])
  @@index([deletedAt])
}

model ModuloPermesso {
  id       String   @id @default(cuid())
  ruolo    Ruolo
  moduloId Int      // 1-7
  visible  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ruolo, moduloId])
  @@index([ruolo])
}

model LogAudit {
  id        String   @id @default(cuid())
  utenteId  String
  utente    ProfiloUtente @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  azione    String   // "LOGIN", "LOGOUT", "CREA_AULA", "CHIUDE_AULA", etc.
  tabella   String?  // tabella interessata
  recordId  String?  // ID del record interessato
  dettagli  Json?    // extra metadata
  createdAt DateTime @default(now())

  @@index([utenteId])
  @@index([createdAt])
  @@index([azione])
}

// ============================================================================
// MODULO 2: IMPORTAZIONE E CATALOGO CORSI
// ============================================================================

enum TipoCorso {
  FORMAZIONE
  AGGIORNAMENTO
}

enum TipoErogazione {
  AULA_FAD
  E_LEARNING
}

model Azienda {
  id              String   @id @default(cuid())
  ragioneSociale  String
  pIva            String   @unique
  codiceFiscale   String   @unique
  emailReferente  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  discenti        Discente[]

  @@index([pIva])
  @@index([deletedAt])
}

model Discente {
  id              String   @id @default(cuid())
  matricola       String?
  cognome         String   // ENCRYPTED
  nome            String   // ENCRYPTED
  dataNascita     DateTime? // ENCRYPTED
  luogoNascita    String?
  codiceFiscale   String   // ENCRYPTED, UNIQUE
  email           String?  // ENCRYPTED
  cellulare       String?  // ENCRYPTED
  aziendaId       String
  azienda         Azienda  @relation(fields: [aziendaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  iscrizioni      IscrizioneAula[]

  @@unique([codiceFiscale])
  @@index([aziendaId])
  @@index([codiceFiscale])
  @@index([deletedAt])
}

model CatalogoCorso {
  codice          String   @id // PK: es. "FORM_BASE"
  titolo          String
  tipo            TipoCorso
  oreAula         Int
  oreElearning    Int      @default(0)
  validitaAnni    Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  aule            Aula[]
  listiniPrezzi   ListinoPrezzi[]
  templates       TemplateMapping[]

  @@index([tipo])
  @@index([deletedAt])
}

model ListinoPrezzi {
  id              String   @id @default(cuid())
  corsoCodec      String
  corso           CatalogoCorso @relation(fields: [corsoCodec], references: [codice], onDelete: Cascade)
  tipoErogazione  TipoErogazione
  costo           Decimal  @db.Decimal(10, 2) // per aula (AULA_FAD) o per discente (E_LEARNING)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  @@unique([corsoCodec, tipoErogazione])
  @@index([corsoCodec])
  @@index([deletedAt])
}

model ImportLog {
  id              String   @id @default(cuid())
  utenteId        String
  utente          ProfiloUtente @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  fileName        String
  rowsProcessed   Int
  errorsCount     Int      @default(0)
  errorsDetail    Json?    // array di errori per riga
  createdAt       DateTime @default(now())

  @@index([utenteId])
  @@index([createdAt])
}

// ============================================================================
// MODULO 3: AULE, LEZIONI, DOCENTI, ISCRIZIONI
// ============================================================================

enum StatoAula {
  PIANIFICATA
  IN_CORSO
  CONCLUSA
}

model Docente {
  id              String   @id @default(cuid())
  cognome         String
  nome            String
  email           String   @unique
  tariffaOraria   Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  docentilezioni  DocenteLezione[]

  @@index([email])
  @@index([deletedAt])
}

model Aula {
  id              String   @id @default(cuid())
  corsoCodec      String
  corso           CatalogoCorso @relation(fields: [corsoCodec], references: [codice], onDelete: Restrict)
  luogo           String
  stato           StatoAula @default(PIANIFICATA)
  dataInizio      DateTime?
  dataFine        DateTime?
  creatoDay       String   // user ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  lezioni         Lezione[]
  iscrizioni      IscrizioneAula[]
  docentilezioni  DocenteLezione[]
  archivio        ArchivioAula[]
  bilancioSnapshot AulaBilancioSnapshot?

  @@index([corsoCodec])
  @@index([stato])
  @@index([dataInizio])
  @@index([deletedAt])
}

model Lezione {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  data            DateTime
  oraInizio       String   // HH:MM
  oraFine         String   // HH:MM
  googleCalendarEventId String? // Google Calendar event ID
  googleCalendarSyncAt DateTime? // Ultimo sync timestamp
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  @@index([aulaId])
  @@index([data])
  @@index([deletedAt])
}

model DocenteLezione {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  docenteId       String
  docente         Docente  @relation(fields: [docenteId], references: [id], onDelete: Restrict)
  oreEffettiveDocenza Decimal @db.Decimal(10, 2)
  trasferAcosto   Decimal  @db.Decimal(10, 2) @default(0) // trasferta costo
  dataInizio      DateTime @default(now()) // quando assegnato
  dataFine        DateTime? // quando sostituito (NULL = ancora attivo)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  aula            Aula
  docente         Docente

  @@index([aulaId])
  @@index([docenteId])
  @@index([dataFine])
  @@index([deletedAt])
}

model IscrizioneAula {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  discenteId      String
  discente        Discente @relation(fields: [discenteId], references: [id], onDelete: Restrict)
  cantiere        String?
  sottocantiere   String?
  responsabile    String?
  attestatoUrl    String?  // Supabase Storage URL
  registroUrl     String?  // Supabase Storage URL
  dataIscrizione  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  @@unique([aulaId, discenteId])
  @@index([aulaId])
  @@index([discenteId])
  @@index([cantiere])
  @@index([deletedAt])
}

model GoogleCalendarConfig {
  id              String   @id @default(cuid())
  utenteId        String   @unique
  utente          ProfiloUtente @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  calendarId      String
  accessTokenEncrypted String // crittografato
  refreshTokenEncrypted String // crittografato
  syncEnabled     Boolean  @default(true)
  expiresAt       DateTime? // scadenza access token
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([utenteId])
}

// ============================================================================
// MODULO 4: MODULISTICA
// ============================================================================

model Template {
  id              String   @id @default(cuid())
  nome            String
  fileUrl         String   // Supabase Storage URL (privato)
  mimeType        String   // application/pdf, application/msword
  creatoDay       String   // user ID
  creatoUtente    ProfiloUtente @relation("createdBy", fields: [creatoDay], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  mappings        TemplateMapping[]

  @@index([creatoDay])
  @@index([deletedAt])
}

model TemplateMapping {
  id              String   @id @default(cuid())
  templateId      String
  template        Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  corsoCodec      String
  corso           CatalogoCorso @relation(fields: [corsoCodec], references: [codice], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([templateId, corsoCodec])
  @@index([templateId])
  @@index([corsoCodec])
}

model ArchivioAula {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  tipoDocumento   String   // "REGISTRO", "VERBALE", "TEST", "ATTESTATO", etc.
  fileUrl         String   // Supabase Storage URL (privato)
  mimeType        String
  uploadDay       String   // user ID
  uploadUtente    ProfiloUtente @relation("uploadedBy", fields: [uploadDay], references: [id], onDelete: Restrict)
  dataUpload      DateTime @default(now())
  createdAt       DateTime @default(now())
  deletedAt       DateTime? // soft-delete (retention 10 anni)

  @@index([aulaId])
  @@index([tipoDocumento])
  @@index([uploadDay])
  @@index([deletedAt])
}

// ============================================================================
// MODULO 5: PREFATTURAZIONE (Snapshot Bilancio)
// ============================================================================

model AulaBilancioSnapshot {
  id              String   @id @default(cuid())
  aulaId          String   @unique
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  ricavo          Decimal  @db.Decimal(12, 2)
  costoTotale     Decimal  @db.Decimal(12, 2)
  margine         Decimal  @db.Decimal(12, 2) // ricavo - costoTotale
  dataChiusura    DateTime // quando aula è andata a CONCLUSA
  createdAt       DateTime @default(now())
  // NOTE: Immutabile dopo creazione. No updates.

  @@index([aulaId])
  @@index([dataChiusura])
}

// ============================================================================
// MODULO 6 & 7: REPORT E CENTRI DI COSTO (Snapshots Calcolati)
// ============================================================================

model CentriCostoSnapshot {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  cantiere        String
  sottocantiere   String?
  responsabile    String?
  costoAttribuito Decimal  @db.Decimal(12, 2)
  dataCalcolo     DateTime @default(now())
  // NOTE: Immutabile dopo creazione. No updates.

  @@index([aulaId])
  @@index([cantiere])
  @@index([dataCalcolo])
}

// ============================================================================
// VIEWS CALCOLATE (READ-ONLY) — Usate per Report
// ============================================================================

// Nota: Queste sono comment-only. In realtà le crei come PostgreSQL views.
// - kpi_aule_attive: COUNT(*) WHERE stato IN (PIANIFICATA, IN_CORSO)
// - kpi_aule_concluse: COUNT(*) WHERE stato = CONCLUSA
// - kpi_discenti_per_corso: discenti GROUP BY corso
// - kpi_costo_medio_discente: SUM(bilancio.margine) / COUNT(iscrizioni)
// - kpi_margine_per_tipo_aula: bilancio GROUP BY corso.tipo

model KpiSnapshot {
  id              String   @id @default(cuid())
  dataCalcolo     DateTime @default(now())
  aulesttiveCount Int
  aulesonclusCount Int
  discentiTotalCount Int
  discentiByCourse Json    // { "FORM_BASE": 45, ... }
  costoMedioDiscente Decimal @db.Decimal(10, 2)
  marginePerTipo  Json    // { "FORMAZIONE": 5000, "AGGIORNAMENTO": 3000 }
  createdAt       DateTime @default(now())

  @@index([dataCalcolo])
}
