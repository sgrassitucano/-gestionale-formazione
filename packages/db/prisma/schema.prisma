// Gestionale Formazione — Prisma Schema
// Database: PostgreSQL (Supabase)
// RLS: Enabled per tutte le tabelle
// Encryption: Via middleware Prisma (CF, data_nascita, cellulare, email)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// MODULO 1: AUTENTICAZIONE E PERMESSI
// ============================================================================

enum Ruolo {
  SUPERADMIN
  SEGRETERIA
  AMMINISTRAZIONE
  VISUALIZZATORE
}

model ProfiloUtente {
  id                   String   @id @default(cuid())
  email                String   // ENCRYPTED (cifrato a riposo)
  emailHash            String   @unique // blind index HMAC di email normalizzata, usato per login/lookup
  passwordHash         String
  ruolo                Ruolo
  nome                 String?
  cognome              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime? // soft-delete

  // Rate limiting login: account-based invece di in-memory, perché su
  // Vercel ogni invocazione serverless può girare su un'istanza diversa —
  // un contatore in-memory per-processo non vedrebbe i tentativi falliti
  // fatti su altre istanze. Persistendo su riga utente il lockout funziona
  // correttamente indipendentemente da quante istanze girano in parallelo.
  tentativiFalliti     Int      @default(0)
  bloccatoFino         DateTime?

  // Relazioni
  logAudit             LogAudit[]
  backupLog            BackupLog[]
  importLog            ImportLog[]
  templatesCreati      Template[] @relation("createdBy")
  archivioUpload       ArchivioAula[] @relation("uploadedBy")
  googleCalendarConfig GoogleCalendarConfig?

  @@index([ruolo])
  @@index([deletedAt])
}

model ModuloPermesso {
  id       String   @id @default(cuid())
  ruolo    Ruolo
  moduloId Int      // 1-7
  visible  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ruolo, moduloId])
  @@index([ruolo])
}

model LogAudit {
  id        String   @id @default(cuid())
  utenteId  String
  utente    ProfiloUtente @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  azione    String   // "LOGIN", "LOGOUT", "CREA_AULA", "CHIUDE_AULA", etc.
  tabella   String?  // tabella interessata
  recordId  String?  // ID del record interessato
  dettagli  Json?    // extra metadata
  createdAt DateTime @default(now())

  @@index([utenteId])
  @@index([createdAt])
  @@index([azione])
}

// Traccia gli export/import di backup dati (apps/web/app/api/admin/backup/*).
// Usata per il promemoria "backup scaduto da oltre 30 giorni" nella pagina
// admin/backup — nessuna notifica push (nessun canale email/Slack nel
// sistema), solo un banner UI + una riga di LogAudit scritta dal cron
// giornaliero se il backup risulta scaduto.
model BackupLog {
  id              String     @id @default(cuid())
  tipo            TipoBackup
  utenteId        String
  utente          ProfiloUtente @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  righeTotali     Int
  dimensioneByte  Int
  createdAt       DateTime   @default(now())

  @@index([tipo])
  @@index([createdAt])
}

enum TipoBackup {
  EXPORT
  IMPORT
}

// ============================================================================
// MODULO 2: IMPORTAZIONE E CATALOGO CORSI
// ============================================================================

enum TipoCorso {
  FORMAZIONE
  AGGIORNAMENTO
}

enum TipoErogazione {
  AULA_FAD
  E_LEARNING
}

model Azienda {
  id              String   @id @default(cuid())
  ragioneSociale  String
  pIva            String   @unique
  codiceFiscale   String   @unique
  emailReferente  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  discenti        Discente[]

  @@index([pIva])
  @@index([deletedAt])
}

model Discente {
  id              String   @id @default(cuid())
  matricola       String?
  cognome         String   // ENCRYPTED
  nome            String   // ENCRYPTED
  dataNascita     String? // ENCRYPTED — testo (non DateTime): la colonna deve contenere ciphertext, decifrata a runtime dal middleware
  luogoNascita    String? // città di nascita
  provinciaNascita String?
  regioneNascita  String?
  codiceFiscale   String   // ENCRYPTED
  codiceFiscaleHash String @unique // blind index HMAC di CF normalizzato, usato per lookup/import/matching
  email           String?  // ENCRYPTED
  cellulare       String?  // ENCRYPTED
  sesso           String? // M/F
  indirizzoResidenza String?
  capResidenza    String?
  cittaResidenza  String?
  provinciaResidenza String?
  regioneResidenza String?
  mansione        String?
  codiceAteco     String?
  aziendaId       String
  azienda         Azienda  @relation(fields: [aziendaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  iscrizioni      IscrizioneAula[]
  archivioDocumenti ArchivioAula[]

  @@index([aziendaId])
  @@index([deletedAt])
}

model CatalogoCorso {
  codice          String   @id // PK: es. "FORM_BASE"
  titolo          String
  tipo            TipoCorso
  oreAula         Int
  oreElearning    Int      @default(0)
  validitaAnni    Int
  modalitaConsentite ModalitaErogazione[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  aule            Aula[]
  listiniPrezzi   ListinoPrezzi[]
  templates       TemplateMapping[]

  @@index([tipo])
  @@index([deletedAt])
}

model ListinoPrezzi {
  id              String   @id @default(cuid())
  corsoCodec      String
  corso           CatalogoCorso @relation(fields: [corsoCodec], references: [codice], onDelete: Cascade)
  tipoErogazione  TipoErogazione
  costo           Decimal  @db.Decimal(10, 2) // per aula (AULA_FAD) o per discente (E_LEARNING)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  @@unique([corsoCodec, tipoErogazione])
  @@index([corsoCodec])
  @@index([deletedAt])
}

model ImportLog {
  id              String   @id @default(cuid())
  utenteId        String
  utente          ProfiloUtente @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  fileName        String
  rowsProcessed   Int
  errorsCount     Int      @default(0)
  errorsDetail    Json?    // array di errori per riga
  createdAt       DateTime @default(now())

  @@index([utenteId])
  @@index([createdAt])
}

// ============================================================================
// MODULO 3: AULE, LEZIONI, DOCENTI, ISCRIZIONI
// ============================================================================

enum StatoAula {
  PIANIFICATA
  IN_CORSO
  CONCLUSA
}

enum ModalitaErogazione {
  PRESENZA
  FAD_SINCRONA
  FAD_ASINCRONA
}

model Docente {
  id              String   @id @default(cuid())
  cognome         String
  nome            String
  email           String   @unique
  tariffaOraria   Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  docentilezioni  DocenteLezione[]

  @@index([email])
  @@index([deletedAt])
}

model Luogo {
  id                    String   @id @default(cuid())
  nome                  String   @unique
  indirizzo             String?
  citta                 String?
  costoMezzaGiornata    Decimal? @db.Decimal(10, 2) // corso <= 4h
  costoGiornataIntera   Decimal? @db.Decimal(10, 2) // corso > 4h
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime? // soft-delete

  // Relazioni
  aule            Aula[]

  @@index([deletedAt])
}

model Aula {
  id              String   @id @default(cuid())
  corsoCodec      String
  corso           CatalogoCorso @relation(fields: [corsoCodec], references: [codice], onDelete: Restrict)
  modalita        ModalitaErogazione
  luogoId         String?
  luogo           Luogo?   @relation(fields: [luogoId], references: [id], onDelete: SetNull)
  stato           StatoAula @default(PIANIFICATA)
  dataInizio      DateTime? // "data aula" — determina anche il mese di fatturazione
  dataFine        DateTime? // per FAD_ASINCRONA: scadenza entro cui completare il corso
  googleCalendarEventId String? // per FAD_ASINCRONA: id evento promemoria scadenza su Google Calendar
  costoAffitto    Decimal  @db.Decimal(10, 2) @default(0)
  creatoDay       String   // user ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  lezioni         Lezione[]
  iscrizioni      IscrizioneAula[]
  docentilezioni  DocenteLezione[]
  archivio        ArchivioAula[]
  chiusura        ChiusuraAula?
  bilancio        BilancioAula?
  centriCosto     CentroCostoSnapshot[]

  @@index([corsoCodec])
  @@index([stato])
  @@index([modalita])
  @@index([dataInizio])
  @@index([deletedAt])
  @@index([luogoId])
}

// Snapshot immutabile creato al momento della chiusura aula (transizione
// IN_CORSO -> CONCLUSA in PUT /api/aule/[aulaId]). "Blocca" ricavo/costi al
// prezzo/tariffe vigenti in quel momento: senza questo, i report Mod.5/6/7
// (prima calcolati sempre live da ListinoPrezzi/Docente.tariffaOraria
// CORRENTI) cambiavano retroattivamente ogni volta che si aggiornava un
// prezzo, anche per aule chiuse e fatturate mesi prima — nessuno storico
// per audit contabile. Un'aula CONCLUSA ha sempre uno snapshot da qui in
// avanti; le aule già CONCLUSA prima di questa migrazione sono state
// backfillate una tantum con i valori correnti al momento del backfill
// (non i valori storici reali, che non erano mai stati registrati).
model BilancioAula {
  id              String   @id @default(cuid())
  aulaId          String   @unique
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  corsoTitolo     String   // denormalizzato: resta leggibile anche se il corso cambia titolo dopo
  modalita        ModalitaErogazione
  discentiCount   Int
  ricavo          Decimal  @db.Decimal(10, 2)
  costoDocenti    Decimal  @db.Decimal(10, 2)
  costoAffitto    Decimal  @db.Decimal(10, 2)
  costoTotale     Decimal  @db.Decimal(10, 2)
  margine         Decimal  @db.Decimal(10, 2)
  marginePct      Decimal  @db.Decimal(6, 2)
  dataChiusura    DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([dataChiusura])
}

// Distribuzione centri di costo per cantiere/sottocantiere, snapshot allo
// stesso momento di BilancioAula (stessa transazione di chiusura). Una riga
// per ogni cantiere/sottocantiere coinvolto nell'aula.
model CentroCostoSnapshot {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  cantiere        String
  sottocantiere   String?
  responsabile    String?
  discentiCount   Int
  costoAttribuito Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  @@index([aulaId])
  @@index([cantiere])
}

model Lezione {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  data            DateTime
  oraInizio       String   // HH:MM
  oraFine         String   // HH:MM
  googleCalendarEventId String? // Google Calendar event ID
  googleCalendarSyncAt DateTime? // Ultimo sync timestamp
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  @@index([aulaId])
  @@index([data])
  @@index([deletedAt])
}

model DocenteLezione {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  docenteId       String
  docente         Docente  @relation(fields: [docenteId], references: [id], onDelete: Restrict)
  oreEffettiveDocenza Decimal @db.Decimal(10, 2)
  trasferAcosto   Decimal  @db.Decimal(10, 2) @default(0) // trasferta costo
  dataInizio      DateTime @default(now()) // quando assegnato
  dataFine        DateTime? // quando sostituito (NULL = ancora attivo)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  @@index([aulaId])
  @@index([docenteId])
  @@index([dataFine])
  @@index([deletedAt])
}

model IscrizioneAula {
  id              String   @id @default(cuid())
  aulaId          String
  aula            Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  discenteId      String
  discente        Discente @relation(fields: [discenteId], references: [id], onDelete: Restrict)
  cantiere        String?
  sottocantiere   String?
  responsabile    String?
  attestatoUrl    String?  // Supabase Storage URL
  registroUrl     String?  // Supabase Storage URL
  dataIscrizione  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  @@unique([aulaId, discenteId])
  @@index([aulaId])
  @@index([discenteId])
  @@index([cantiere])
  @@index([deletedAt])
}

model GoogleCalendarConfig {
  id              String   @id @default(cuid())
  utenteId        String   @unique
  utente          ProfiloUtente @relation(fields: [utenteId], references: [id], onDelete: Cascade)
  calendarId      String
  accessTokenEncrypted String // crittografato
  refreshTokenEncrypted String // crittografato
  syncEnabled     Boolean  @default(true)
  expiresAt       DateTime? // scadenza access token
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([utenteId])
}

// ============================================================================
// MODULO IMPOSTAZIONI: SYSTEM SETTINGS (Google OAuth App Credentials, etc.)
// ============================================================================

model SystemSettings {
  id                    String   @id @default(cuid())
  chiave                String   @unique // "google_oauth_client_id", "google_oauth_client_secret", etc.
  valoreEncrypted       String
  descrizione           String?
  updatedBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([chiave])
}

// ============================================================================
// MODULO 4: MODULISTICA
// ============================================================================

enum TipoGenerazioneTemplate {
  PER_DISCENTE    // un documento per ogni discente iscritto (es. test individuale)
  PER_AULA_LISTA  // un documento per aula, con tabella discenti ripetuta (es. registro presenze)
  PER_AULA_SEMPLICE // un documento per aula, nessun dato discente-specifico
  STATICO         // documento di riferimento, scaricabile così com'è, non generato
}

model Template {
  id              String   @id @default(cuid())
  nome            String
  fileUrl         String   // Supabase Storage URL (privato)
  mimeType        String   // application/pdf, application/msword
  tipoGenerazione TipoGenerazioneTemplate @default(PER_AULA_SEMPLICE)
  creatoDay       String   // user ID
  creatoUtente    ProfiloUtente @relation("createdBy", fields: [creatoDay], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft-delete

  // Relazioni
  mappings        TemplateMapping[]
  campi           TemplateField[]

  @@index([creatoDay])
  @@index([deletedAt])
}

model TemplateField {
  id              String   @id @default(cuid())
  templateId      String
  template        Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  nomeCampo       String   // es. "nome_discente", "data_lezione"
  placeholder     String   // testo trovato nel documento, es. "{{nome_discente}}"
  sorgenteDato    String   // es. "discente.nome", "aula.dataInizio", "docente.nome" — path per lookup
  createdAt       DateTime @default(now())

  @@unique([templateId, placeholder])
  @@index([templateId])
}

model TemplateMapping {
  id              String   @id @default(cuid())
  templateId      String
  template        Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  corsoCodec      String? // null = vale per tutti i corsi
  corso           CatalogoCorso? @relation(fields: [corsoCodec], references: [codice], onDelete: Cascade)
  modalita        ModalitaErogazione? // null = vale per tutte le modalità del corso
  createdAt       DateTime @default(now())

  @@unique([templateId, corsoCodec, modalita])
  @@index([templateId])
  @@index([corsoCodec])
}

model ArchivioAula {
  id                  String   @id @default(cuid())
  aulaId              String
  aula                Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  tipoDocumento       String   // "REGISTRO", "RESOCONTO", "TEST_INTERMEDI", "TEST_FINALE", "GRADIMENTO",
                                // "FASCICOLO", "EBAFOS", "PIATTAFORMA", "LISTA_CORSISTI",
                                // "AUTODICHIARAZIONE", "ATTESTATO", "REPORT_QUESTIONARIO"
  fase                FaseChiusuraDocumento @default(DOCUMENTI) // in quale fase del flow di chiusura è stato caricato
  discenteId          String?  // null per documenti a livello aula (Registro, EBAFOS, Autodichiarazione, ecc.)
  discente            Discente? @relation(fields: [discenteId], references: [id], onDelete: SetNull)
  fileUrl             String   // Supabase Storage URL (privato)
  mimeType            String
  metodoClassificazione String? // "OCR", "CF_MATCH", "MANUALE", null se non applicabile (upload aula-level)
  confidenza          Decimal? @db.Decimal(4, 3) // 0.000-1.000, solo per classificazione OCR
  uploadDay           String   // user ID
  uploadUtente        ProfiloUtente @relation("uploadedBy", fields: [uploadDay], references: [id], onDelete: Restrict)
  dataUpload          DateTime @default(now())
  createdAt           DateTime @default(now())
  deletedAt           DateTime? // soft-delete (retention 10 anni)

  @@index([aulaId])
  @@index([tipoDocumento])
  @@index([discenteId])
  @@index([fase])
  @@index([uploadDay])
  @@index([deletedAt])
}

enum FaseChiusuraDocumento {
  DOCUMENTI // registro/resoconto/test/questionario/fascicolo/caricamenti iniziali
  ATTESTATI // fase 2, sblocca il countdown
}

enum FaseChiusuraAula {
  DOCUMENTI          // aula CONCLUSA, upload documenti in corso, countdown non ancora avviato
  ATTESA_ATTESTATI   // documenti confermati, in attesa upload attestati
  COUNTDOWN          // attestati caricati, countdown eliminazione avviato
  COMPLETATA         // countdown scaduto, upload temporanei cancellati, archivio finale conservato
}

model ChiusuraAula {
  id                      String   @id @default(cuid())
  aulaId                  String   @unique
  aula                    Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)
  fase                    FaseChiusuraAula @default(DOCUMENTI)
  countdownAvviatoAt      DateTime? // timestamp inizio countdown (set al passaggio a COUNTDOWN)
  dataEliminazionePrevista DateTime? // countdownAvviatoAt + 7 giorni, letta dal cron Vercel
  confermatoDay           String?   // user ID che ha confermato chiusura fase documenti
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([fase])
  @@index([dataEliminazionePrevista])
}

// ============================================================================
// MODULO 5/6/7: PREFATTURAZIONE, BILANCIO, KPI, CENTRI COSTO
// Tutti live-computed da Aula/IscrizioneAula/DocenteLezione/ListinoPrezzi,
// filtrati per mese via Aula.dataInizio. Nessuno snapshot persistito.
// ============================================================================

enum TipoVoce {
  ENTRATA
  USCITA
}

model VoceContabile {
  id              String    @id @default(cuid())
  descrizione     String
  categoria       String    // es. "Piattaforma", "EBAFOS", "Altro" — libero
  tipo            TipoVoce
  importo         Decimal   @db.Decimal(10, 2)
  dataInizio      DateTime  // mese/anno da cui la voce è attiva
  dataFine        DateTime? // null = ancora attiva (se ricorrente) o coincide con dataInizio (se una tantum)
  ricorrente      Boolean   @default(false) // true = si somma ogni mese tra dataInizio e dataFine (o oggi)
  creatoDay       String    // user ID
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? // soft-delete

  @@index([tipo])
  @@index([categoria])
  @@index([dataInizio])
  @@index([deletedAt])
}
